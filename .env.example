# Supabase — public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Supabase — server-only (do NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Site URL — used for magic-link redirects (e.g. https://khinext26.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — for confirmation emails (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The verified sender. With Resend you must either verify the domain
# or, for testing, use "onboarding@resend.dev".
EMAIL_FROM=TEDxClifton <hello@tedxclifton.com>
EMAIL_REPLY_TO=hello@tedxclifton.com

# SMTP — for SENDING bulk invitation emails (mail.tedxclifton.com, port 465, SSL)
SMTP_HOST=mail.tedxclifton.com
SMTP_PORT=465
SMTP_USER=hello@tedxclifton.com
SMTP_PASS=your-smtp-password-here

# Gmail REST API — for the "Sync" button in the admin inbox (preferred over IMAP).
# 1. Go to console.cloud.google.com → create a project → enable Gmail API.
# 2. Create OAuth 2.0 credentials (Desktop or Web app type).
# 3. Run the OAuth consent flow once to get a refresh token (use OAuth Playground
#    at developers.google.com/oauthplayground with scope gmail.readonly).
# 4. Paste the values below.
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
# Optional: override the Gmail search query (default shown below).
# GMAIL_SEARCH_QUERY=to:hello@tedxclifton.com

# IMAP — legacy fallback for SYNCING the admin inbox (READING mail). Falls back to SMTP_* if unset.
# IMAP — for SYNCING the admin inbox (READING mail). Falls back to SMTP_* if unset.
# Recommended: read from Gmail, where all hello@tedxclifton.com mail reliably lands.
#   1. In Gmail: turn on 2-Step Verification, then create an App Password
#      (Google Account → Security → App passwords).
#   2. In Gmail: Settings → Forwarding and POP/IMAP → enable IMAP.
#   3. Set the vars below to that Gmail account + the 16-char App Password.
# Tip: IMAP_FOLDER="[Gmail]/All Mail" pulls the full history, not just new INBOX mail.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-gmail-address@gmail.com
IMAP_PASS=your-16-char-app-password
# Gmail auto-labels POP3-imported mail with the source address — read that
# label as a folder so only khinext mail is scanned (not your personal inbox).
IMAP_FOLDER=hello@tedxclifton.com
# Safety net: only ingest mail addressed to these (comma-separated). Defaults
# to SMTP_USER. Set to "off" to disable. Keeps personal mail out even if the
# folder above contains a mix.
IMAP_FILTER_TO=hello@tedxclifton.com
